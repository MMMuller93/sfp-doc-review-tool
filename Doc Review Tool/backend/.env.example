# Google Gemini API Configuration (v1 — kept for backwards compatibility)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic API Configuration (v2 — Claude for review/verification)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Configuration (v2 — GPT-5.2 for analysis)
OPENAI_API_KEY=your_openai_api_key_here

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URLs (for CORS)
FRONTEND_URL_LOCAL=http://localhost:5173
FRONTEND_URL_PROD=https://your-github-pages-url.com
